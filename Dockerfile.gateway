FROM alpine/openclaw:latest
RUN cd /tmp && npm install nunjucks
ENV NODE_PATH=/tmp/node_modules
RUN install -d -m 700 /home/node/.ssh
ADD files/gateway-entrypoint.sh /entrypoint.sh
ADD files/render-config.js /render-config.js
ADD files/openclaw.json.j2 /openclaw.json.j2.default
ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "dist/index.js", "gateway", "--bind", "lan", "--port", "18789"]
