{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "tools": {
    "fs": {
      "workspaceOnly": true
    },
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 3,
      "criticalThreshold": 5,
      "globalCircuitBreakerThreshold": 10
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4"
      },
      "sandbox": {
        "mode": "all",
        "backend": "ssh",
        "scope": "session",
        "workspaceAccess": "rw",
        "ssh": {
          "target": "somebody@openclaw-sandbox:22",
          "workspaceRoot": "/home/somebody/workspaces",
          "strictHostKeyChecking": false,
          "identityFile": "/home/node/.ssh/id_ed25519"
        }
      }
    }
  },
  "plugins": {
    "enabled": true,
    "entries": {
      "voice-call": {
        "enabled": true,
        "config": {
          "provider": "mock"
        }
      }
    }
  }
}